{
    "name": "dodgycode/craft-bunny-storage",
    "description": "A bunny.net storage adapter for Craft CMS",
    "type": "craft-plugin",
    "license": "proprietary",
    "keywords": [
        "bunny.net",
        "craft",
        "cms",
        "craftcms",
        "craft-plugin",
        "flysystem",
        "storage",
        "yii2"
    ],
    "authors": [
        {
            "name": "Alex Brindly",
            "homepage": "https://brindly.art"
        }
    ],
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^4.0|^5.0",
        "craftcms/flysystem": "^1.0|^2.0",
        "league/flysystem-path-prefixing": "*",
        "platformcommunity/flysystem-bunnycdn": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "DodgyCode\\BunnyStorage\\": "src/"
        }
    },
    "support": {
        "docs": "https://github.com/dodgycde/craft-bunny-storage",
        "source": "https://github.com/dodgycde/craft-bunny-storage",
        "issues": "https://github.com/dodgycde/craft-bunny-storage/issues"
    },
    "extra": {
        "handle": "bunny-storage",
        "name": "Bunny Storage",
        "description": "A bunny.net storage adapter for CraftCMS",
        "developer": "Dodgy Code",
        "developerUrl": "https://dodgyco.de/",
        "documentationUrl": "https://github.com/dodgycde/craft-bunny-storage",
        "changelogUrl": "https://raw.githubusercontent.com/dodgycde/craft-bunny-storage/main/CHANGELOG.md"
    }
}
